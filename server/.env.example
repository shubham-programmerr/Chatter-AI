# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (REPLACE WITH YOUR ACTUAL CREDENTIALS)
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/chatterai?retryWrites=true&w=majority

# JWT Secret (REPLACE WITH YOUR ACTUAL SECRET IN PRODUCTION)
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Groq API Key (Get from https://console.groq.com)
GROQ_API_KEY=your_actual_groq_api_key_here

# Google OAuth (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_actual_google_client_id_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000