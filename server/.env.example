# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chatterai?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Groq API Key (for Mixtral Bot)
GROQ_API_KEY=gsk-your_groq_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_from_cloud_console

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000